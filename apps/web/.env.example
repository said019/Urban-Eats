# ─────────────────────────────────────────────────────────────
#  Variables de entorno — Bunsik / Urban Eats (apps/web)
#  Copia este archivo a `.env.local` y rellena los valores reales.
#  `.env.local` está en .gitignore: NO se sube al repo.
# ─────────────────────────────────────────────────────────────

# Secreto para firmar/verificar los tokens JWT del panel admin.
#
# CRÍTICO: debe ser EXACTAMENTE EL MISMO valor en todos los entornos e
# instancias (local, staging, producción, cada réplica del server). Si una
# instancia firma el token con un secreto y otra lo verifica con otro, el
# token se rechaza con 401 y "no cargan los datos" en el panel (típico en
# celular, donde el token vive solo en localStorage de ese dispositivo).
#
# Si esta variable NO está definida, el código usa un fallback fijo
# ('URBAN_EATS_DEFAULT_SUPER_SECRET') que NO debe usarse en producción.
#
# Genera uno fuerte:  openssl rand -base64 48
JWT_SECRET=pon-aqui-un-secreto-largo-y-unico-y-el-mismo-en-todos-lados

# Cadena de conexión a Postgres.
DATABASE_URL=postgresql://root:password@localhost:5432/urban_eats
